#include "ma35d1.dtsi"
#include <dt-bindings/leds/common.h>
#include <dt-bindings/net/mscc-phy-vsc8531.h>
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/interrupt-controller/irq.h>

/ {
	model = "EMAC SOM-35D1F";
	compatible = "emac,som35d1f", "nuvoton,ma35d1";
	chosen {
		bootargs = "root=/dev/mmcblk1p1 rootfstype=ext4 rw rootwait console=ttyS0,115200n8 rdinit=/sbin/init mem=512M";
	};

	general_3v3_regulator: general_3v3_regulator {
		compatible = "regulator-fixed";
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		regulator-name = "general_3v3_regulator";
		regulator-always-on;
	};

	general_1v8_regulator: general_1v8_regulator {
		compatible = "regulator-fixed";
		regulator-min-microvolt = <1800000>;
		regulator-max-microvolt = <1800000>;
		regulator-name = "general_1v8_regulator";
		regulator-always-on;
	};

	general_1v2_regulator: general_1v2_regulator {
		compatible = "regulator-fixed";
		regulator-min-microvolt = <1200000>;
		regulator-max-microvolt = <1200000>;
		regulator-name = "general_1v2_regulator";
		regulator-always-on;
	};

	volt0_sdhci1: regulator-volt0_sdhci1 {
		compatible = "nuvoton,ma35d1-volt";
		regulator-min-microvolt = <1800000>;
		regulator-max-microvolt = <3300000>;
		regulator-name = "volt0_sdhci1";
		regulator-always-on;
	};


	// hacky as fuck. I need to drive this pin high so that the "other" pins route to the right places in the mux -> gpiog
	gpio_leds_test {
		compatible = "gpio-leds";
		pinctrl-names = "default";
		pinctrl-0 = <&pinctrl_mux_ctrl>;
		status = "okay";
		mux_ctrl {
			label = "MUX_CTRL";
			gpios = <&gpioa 12 GPIO_ACTIVE_HIGH>;
			default-state = "on";
	};
};

};

// all options come with 512 MB
&mem {
	device_type = "memory";
	reg = <0x00000000 0x80000000 0 0x20000000>;
};

